/*
===============================================================
                SUMMER COURSE 2026
          BATTERY MONITORING SYSTEM
===============================================================

Board          : NodeMCU ESP8266
Sensor         : INA219
Cloud Platform : ThingsBoard Cloud
Protocol       : MQTT

Telemetry:
- Voltage 
- Current 
- Power (Calculated)

===============================================================
*/

#include <ESP8266WiFi.h>
#include <PubSubClient.h>
#include <Wire.h>
#include <Adafruit_INA219.h>

//==================================================
// WiFi Configuration
//==================================================

const char* ssid = "IoT";
const char* password = "agusramelan";

//==================================================
// ThingsBoard MQTT
//==================================================

const char* mqtt_server = "mqtt.thingsboard.cloud";
const int mqtt_port = 1883;
const char* accessToken = "43dqfgtx5ipsc5j2hwon";

//==================================================

WiFiClient espClient;
PubSubClient client(espClient);
Adafruit_INA219 ina219;

unsigned long lastSend = 0;

//==================================================
// WiFi
//==================================================

void connectWiFi()
{
  Serial.println();
  Serial.println("==========================================");
  Serial.println("Connecting to WiFi...");
  Serial.println("==========================================");

  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED)
  {
    delay(500);
    Serial.print(".");
  }

  Serial.println();
  Serial.println("WiFi Connected");
  Serial.print("SSID : ");
  Serial.println(ssid);

  Serial.print("IP Address : ");
  Serial.println(WiFi.localIP());

  Serial.print("RSSI : ");
  Serial.print(WiFi.RSSI());
  Serial.println(" dBm");

  Serial.println("==========================================");
}

//==================================================
// MQTT
//==================================================

void reconnect()
{
  while (!client.connected())
  {
    Serial.print("Connecting to ThingsBoard... ");

    if (client.connect("ESP8266_Battery", accessToken, NULL))
    {
      Serial.println("SUCCESS");
    }
    else
    {
      Serial.print("FAILED (");
      Serial.print(client.state());
      Serial.println(")");

      delay(5000);
    }
  }
}

//==================================================

void setup()
{
  Serial.begin(115200);

  Wire.begin(D2, D1);

  Serial.println();
  Serial.println("==========================================");
  Serial.println("SUMMER COURSE 2026");
  Serial.println("BATTERY MONITORING SYSTEM");
  Serial.println("==========================================");

  if (!ina219.begin())
  {
    Serial.println("INA219 NOT FOUND!");
    while (1);
  }

  Serial.println("INA219 READY");

  connectWiFi();

  client.setServer(mqtt_server, mqtt_port);
}

//==================================================

void loop()
{
  if (WiFi.status() != WL_CONNECTED)
    connectWiFi();

  if (!client.connected())
    reconnect();

  client.loop();

  if (millis() - lastSend >= 5000)
  {
    lastSend = millis();

    //------------------------------------------
    // Read Current Only
    //------------------------------------------

    float current = ina219.getCurrent_mA() / 1000.0;

    //------------------------------------------
    //------------------------------------------

    float voltage = 3.30;

    //------------------------------------------
    // Calculate Power
    //------------------------------------------

    float power = voltage * current;

    //------------------------------------------
    // JSON
    //------------------------------------------

    String payload = "{";
    payload += "\"voltage\":";
    payload += String(voltage, 2);
    payload += ",";
    payload += "\"current\":";
    payload += String(current, 3);
    payload += ",";
    payload += "\"power\":";
    payload += String(power, 2);
    payload += "}";

    //------------------------------------------
    // Serial Monitor
    //------------------------------------------

    Serial.println();
    Serial.println("=======================================================");
    Serial.println("           SUMMER COURSE 2026");
    Serial.println("        BATTERY MONITORING SYSTEM");
    Serial.println("=======================================================");

    Serial.println("Device Information");
    Serial.println("-------------------------------------------------------");

    Serial.print("Board          : ");
    Serial.println("ESP8266 NodeMCU");

    Serial.print("Sensor         : ");
    Serial.println("INA219");

    Serial.print("WiFi RSSI      : ");
    Serial.print(WiFi.RSSI());
    Serial.println(" dBm");

    Serial.println();

    Serial.println("Measurement");
    Serial.println("-------------------------------------------------------");

    Serial.print("Voltage        : ");
    Serial.print(voltage,2);
    Serial.println(" V ");

    Serial.print("Current        : ");
    Serial.print(current,3);
    Serial.println(" A");

    Serial.print("Power          : ");
    Serial.print(power,2);
    Serial.println(" W");

    Serial.println();

    Serial.println("Telemetry");
    Serial.println("-------------------------------------------------------");

    Serial.println(payload);

    Serial.println();

    bool status = client.publish(
      "v1/devices/me/telemetry",
      payload.c_str());

    Serial.println("MQTT");
    Serial.println("-------------------------------------------------------");

    if(status)
    {
      Serial.println("Status         : SUCCESS");
      Serial.println("Telemetry Sent : YES");
    }
    else
    {
      Serial.println("Status         : FAILED");
      Serial.println("Telemetry Sent : NO");
    }

    Serial.println("=======================================================");
  }
}
